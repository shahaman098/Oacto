# Voice / agent integrations
ELEVENLABS_API_KEY=
# Optional: pin an existing agent. Without this, the API finds or creates the demo agent by name.
ELEVENLABS_AGENT_ID=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Optional LLM extraction provider (server-side only)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
DEEPSEEK_API_KEY=

# Optional live web verification (server-side only)
TAVILY_API_KEY=

# App configuration
VITE_DEMO_MODE=true
# Set true only when you intentionally want live provider attempts from the Vite API middleware
ALLOW_LIVE_PROVIDERS=false
API_PORT=8791
